# Target for the Vite dev server proxy (aegis-core base URL).
# Leave empty to use the default: https://aegis-dev.preprodcxr.co
# VITE_AEGIS_PROXY_TARGET=https://aegis-dev.preprodcxr.co

# Public origin that aegis-core will use to validate the DPoP htu claim.
# Must match the host the browser actually sees in the URL bar.
# VITE_AEGIS_PUBLIC_ORIGIN=https://aegis-dev.preprodcxr.co

# Server-side only: injected as X-Internal-API-Key for /internal/* requests.
# NEVER expose this value to the browser; keep it in .env (not .env.example).
VITE_AEGIS_INTERNAL_API_KEY=
